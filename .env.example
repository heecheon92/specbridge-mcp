# SpecBridge MCP runtime
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_HTTP_PATH=/mcp
MCP_HTTP_STATELESS=false

# Backend registry
DEFAULT_BACKEND_ID=swagger-petstore
OPENAPI_BACKENDS_FILE=openapi.backends.json
# OPENAPI_BACKENDS='[{"id":"local-service","name":"Local Service API","specUrl":"http://localhost:8080/openapi.json"}]'

# Spec loading
OPENAPI_FETCH_TIMEOUT_MS=12000
OPENAPI_CACHE_TTL_MS=300000
OPENAPI_ENABLE_SWAGGER_UI_SCRIPT_EXTRACTION=false
