{
  "name": "specbridge-mcp",
  "version": "0.1.0",
  "description": "Clone-and-own MCP starter for exposing OpenAPI/Huma contract intelligence to AI agents.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "main": "build/index.js",
  "scripts": {
    "build": "rm -rf build && tsc && chmod 755 build/index.js",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "start": "node build/index.js --transport stdio",
    "start:http": "node build/index.js --transport http --host 127.0.0.1 --port 3000 --path /mcp",
    "start:http:stateless": "node build/index.js --transport http --host 127.0.0.1 --port 3000 --path /mcp --stateless",
    "test": "pnpm build && node --test \"tests/**/*.test.mjs\"",
    "test:e2e": "pnpm build && node --test \"tests/e2e/**/*.test.mjs\"",
    "mcp": "./mcp-server.sh",
    "mcp:http": "./mcp-server.sh --transport http --host 127.0.0.1 --port 3000 --path /mcp",
    "mcp:http:stateless": "./mcp-server.sh --transport http --host 127.0.0.1 --port 3000 --path /mcp --stateless"
  },
  "keywords": [
    "mcp",
    "openapi",
    "huma",
    "api-contracts",
    "ai-agents"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "build",
    "README.md",
    "openapi.backends.example.json"
  ],
  "bin": {
    "specbridge-mcp": "./build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3"
  }
}
